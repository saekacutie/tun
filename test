#!/data/data/com.termux/files/usr/bin/bash
# VLESS Termux Manager - Prvtspyyy404

SERVICE_NAME="prvtspyyy404"
REGION="us-central1"

show_connections() {
    echo ""
    echo "══════════════════════════════════════════════════"
    echo "              CONNECTED USERS"
    echo "══════════════════════════════════════════════════"
    echo ""
    
    gcloud logging read "resource.type=cloud_run_revision AND resource.labels.service_name=$SERVICE_NAME AND textPayload:\"accepted\"" \
        --freshness=1h --format="value(textPayload)" 2>/dev/null | \
        grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | sort | uniq -c | sort -rn | \
        while read count ip; do
            echo "  IP: $ip | Connections: $count"
        done
    
    echo ""
    echo "══════════════════════════════════════════════════"
}

show_status() {
    echo ""
    echo "══════════════════════════════════════════════════"
    echo "              SERVER STATUS"
    echo "══════════════════════════════════════════════════"
    echo ""
    
    URL=$(gcloud run services describe "$SERVICE_NAME" --region="$REGION" --format="value(status.url)" 2>/dev/null)
    STATUS=$(gcloud run services describe "$SERVICE_NAME" --region="$REGION" --format="value(status.conditions[0].status)" 2>/dev/null)
    
    echo "  Service: $SERVICE_NAME"
    echo "  Region: $REGION"
    echo "  URL: $URL"
    
    if [ "$STATUS" = "True" ]; then
        echo "  Status: ONLINE"
    else
        echo "  Status: OFFLINE"
    fi
    
    echo ""
    echo "══════════════════════════════════════════════════"
}

clear
echo "══════════════════════════════════════════════════"
echo "         VLESS TERMUX MANAGER - Prvtspyyy404"
echo "══════════════════════════════════════════════════"
echo ""
echo "  [1] View Connected Users"
echo "  [2] View Server Status"
echo "  [3] View Recent Logs"
echo "  [4] Exit"
echo ""
read -p "Select option [1-4]: " choice

case $choice in
    1) show_connections ;;
    2) show_status ;;
    3) gcloud logging read "resource.type=cloud_run_revision AND resource.labels.service_name=$SERVICE_NAME" --freshness=30m --limit=15 2>/dev/null ;;
    4) exit 0 ;;
    *) echo "Invalid option" ;;
esac
